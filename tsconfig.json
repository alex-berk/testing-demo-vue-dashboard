{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["cypress", "node", "vite/client", "vitest/globals"]
  },
  "include": [
    "cypress.config.ts",
    "cypress/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.d.ts"
  ]
}
