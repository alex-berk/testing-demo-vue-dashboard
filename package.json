{
  "name": "vite-demo-web-testing",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:api": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "cypress run --e2e",
    "test:component": "cypress run --component",
    "cy:open": "cypress open"
  },
  "dependencies": {
    "express": "^4.21.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/compiler-sfc": "^3.5.13",
    "concurrently": "^9.1.2",
    "cypress": "^13.17.0",
    "cypress-visual-eval": "^0.0.6",
    "jsdom": "^24.1.3",
    "start-server-and-test": "^2.0.8",
    "typescript": "^5.8.3",
    "vite": "^5.4.11",
    "vitest": "^1.6.1"
  }
}
